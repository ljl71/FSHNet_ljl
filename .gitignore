# Python/cache artifacts
__pycache__/
*.py[cod]
*.pyd
*.so

# Training/runtime outputs
output/
outputs/
runs/
logs/
tensorboard/
wandb/

# Checkpoints and generated evaluation/data artifacts
*.pth
*.pt
*.ckpt
*.pkl
*.npy
*.npz
*.bin
